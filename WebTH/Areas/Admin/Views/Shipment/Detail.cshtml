@model WebTH.Models.EF.Shipment
@{ ViewBag.Title = "Chi tiết vận đơn"; }

<section class="content">
    <div class="row">
        <!-- Thông tin vận đơn -->
        <div class="col-md-4">
            <div class="card card-primary">
                <div class="card-header"><h3 class="card-title">Vận đơn</h3></div>
                <div class="card-body">
                    <p><strong>Mã vận đơn:</strong> @Model.TrackingCode</p>
                    <p><strong>Đơn vị:</strong> @Model.Provider?.Name</p>
                    <p>
                        <strong>Trạng thái:</strong>
                        <span class="badge badge-@Model.Status?.Color">@Model.Status?.Name</span>
                    </p>
                    <p>
                        <strong>Phí vận chuyển:</strong>
                        @WebTH.Common.Common.FormatNumber(Model.ShippingFee, 0)₫
                    </p>
                    <p>
                        <strong>Dự kiến giao:</strong>
                        @(Model.EstimatedDelivery?.ToString("dd/MM/yyyy") ?? "—")
                    </p>
                    @if (Model.DeliveredDate.HasValue)
                    {
                        <p>
                            <strong>Đã giao lúc:</strong>
                            @Model.DeliveredDate.Value.ToString("dd/MM/yyyy HH:mm")
                        </p>
                    }
                </div>
            </div>

            <!-- Cập nhật trạng thái -->
            <div class="card card-warning">
                <div class="card-header"><h3 class="card-title">Cập nhật trạng thái</h3></div>
                <div class="card-body">
                    <div class="form-group">
                        <label>Trạng thái mới</label>
                        <select class="form-control" id="newStatusId">
                            @foreach (var s in (List<WebTH.Models.EF.OrderStatus>)ViewBag.Statuses)
                            {
                                <option value="@s.Id">@s.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Vị trí hàng hiện tại</label>
                        <input type="text" class="form-control" id="location"
                               placeholder="VD: Kho Hà Nội, Đang trên đường..." />
                    </div>
                    <div class="form-group">
                        <label>Ghi chú</label>
                        <textarea class="form-control" id="statusNote" rows="2"></textarea>
                    </div>
                    <button class="btn btn-warning btn-block" id="btnUpdateStatus">
                        <i class="fa fa-save"></i> Cập nhật
                    </button>
                </div>
            </div>
        </div>

        <!-- Timeline lịch sử -->
        <div class="col-md-8">
            <div class="card">
                <div class="card-header"><h3 class="card-title">Lịch sử vận chuyển</h3></div>
                <div class="card-body">
                    <div class="timeline" id="timeline">
                        @foreach (var h in Model.Histories.OrderByDescending(x => x.CreatedDate))
                        {
                            <div class="time-label">
                                <span class="bg-@h.Status?.Color">@h.CreatedDate.ToString("dd/MM/yyyy")</span>
                            </div>
                            <div>
                                <i class="fa fa-truck bg-@h.Status?.Color"></i>
                                <div class="timeline-item">
                                    <span class="time">
                                        <i class="fa fa-clock-o"></i> @h.CreatedDate.ToString("HH:mm")
                                    </span>
                                    <h3 class="timeline-header">@h.Status?.Name</h3>
                                    <div class="timeline-body">
                                        @if (!string.IsNullOrEmpty(h.Location))
                                        {<p><i class="fa fa-map-marker"></i> @h.Location</p>}
                                        @if (!string.IsNullOrEmpty(h.Note))
                                        {<p>@h.Note</p>}
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Sản phẩm trong đơn -->
            <div class="card">
                <div class="card-header"><h3 class="card-title">Sản phẩm</h3></div>
                <div class="card-body table-responsive">
                    <table class="table table-sm">
                        <thead><tr><th>Sản phẩm</th><th>SL</th><th>Đơn giá</th><th>Thành tiền</th></tr></thead>
                        <tbody>
                            @foreach (var d in Model.Order.OrderDetails)
                            {
                                <tr>
                                    <td>@d.Product?.Title</td>
                                    <td>@d.Quantity</td>
                                    <td>@WebTH.Common.Common.FormatNumber(d.Price, 0)₫</td>
                                    <td>@WebTH.Common.Common.FormatNumber(d.Price * d.Quantity, 0)₫</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>

@section scripts {
    <script>
$('#btnUpdateStatus').on('click', function () {
    $.post('/admin/shipment/updatestatus', {
        shipmentId: @Model.Id,
        statusId  : $('#newStatusId').val(),
        note      : $('#statusNote').val(),
        location  : $('#location').val()
    }, function (rs) {
        if (rs.Success) { location.reload(); }
        else { alert(rs.msg); }
    });
});
    </script>
}