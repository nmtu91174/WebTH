@model WebTH.Models.VetDoctor

@{
    ViewBag.Title = "Thêm Bác Sĩ Mới";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1 class="mb-4">
                <i class="fas fa-user-md"></i> Thêm Bác Sĩ Mới
            </h1>
            <p class="text-muted">Phòng khám: <strong>@ViewBag.ClinicName</strong></p>

            @using (Html.BeginForm("CreateDoctor", "AdminVet", new { Area = "Admin" }, FormMethod.Post, new { @class = "" }))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.ClinicId)

                <div class="card">
                    <div class="card-body">
                        <!-- Doctor Name -->
                        <div class="form-group mb-3">
                            <label for="DoctorName" class="form-label"><strong>Tên Bác Sĩ *</strong></label>
                            @Html.TextBoxFor(m => m.DoctorName, new { @class = "form-control", placeholder = "Nhập tên bác sĩ" })
                            @Html.ValidationMessageFor(m => m.DoctorName, "", new { @class = "text-danger small mt-1" })
                        </div>

                        <!-- Specialization -->
                        <div class="form-group mb-3">
                            <label for="Specialization" class="form-label"><strong>Chuyên Môn *</strong></label>
                            @Html.TextBoxFor(m => m.Specialization, new { @class = "form-control", placeholder = "VD: Phẫu thuật, Da liễu" })
                            @Html.ValidationMessageFor(m => m.Specialization, "", new { @class = "text-danger small mt-1" })
                        </div>

                        <!-- Experience Years -->
                        <div class="form-group mb-3">
                            <label for="ExperienceYears" class="form-label"><strong>Năm Kinh Nghiệm</strong></label>
                            @Html.TextBoxFor(m => m.ExperienceYears, new { @class = "form-control", placeholder = "10", type = "number" })
                        </div>

                        <!-- Qualifications -->
                        <div class="form-group mb-3">
                            <label for="Qualifications" class="form-label"><strong>Bằng Cấp & Chứng Chỉ</strong></label>
                            @Html.TextAreaFor(m => m.Qualifications, new { @class = "form-control", placeholder = "Liệt kê các bằng cấp và chứng chỉ", rows = 3 })
                        </div>

                        <!-- Bio -->
                        <div class="form-group mb-3">
                            <label for="Bio" class="form-label"><strong>Tiểu Sử</strong></label>
                            @Html.TextAreaFor(m => m.Bio, new { @class = "form-control", placeholder = "Mô tả ngắn về bác sĩ", rows = 3 })
                        </div>

                        <!-- Avatar -->
                        <div class="form-group mb-3">
                            <label for="Avatar" class="form-label"><strong>Ảnh Đại Diện</strong></label>
                            <div class="input-group">
                                @Html.TextBoxFor(m => m.Avatar, new { @class = "form-control", @id = "Avatar", placeholder = "Đường dẫn ảnh đại diện" })
                                <div class="input-group-append">
                                    <button class="btn btn-primary" type="button" onclick="BrowseServer('Avatar')">Chọn ảnh</button>
                                </div>
                            </div>
                            <small class="form-text text-muted d-block mt-2">
                                Nhấn "Chọn ảnh" để chọn avatar từ thư viện ảnh.
                            </small>
                            <div class="mt-3" id="AvatarPreview" style="display:none;">
                                <p style="margin: 0 0 10px 0; color: #666; font-size: 0.9em;"><strong>Xem trước avatar:</strong></p>
                                <img id="PreviewAvatar" src="" alt="Avatar Preview" style="max-width: 150px; max-height: 150px; border-radius: 8px; object-fit: cover;" />
                            </div>
                        </div>

                        <!-- Buttons -->
                        <div class="form-group">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-save"></i> Thêm Bác Sĩ
                            </button>
                            <a href="@Url.Action("DoctorList", "AdminVet", new { Area = "Admin", id = ViewBag.ClinicId })" class="btn btn-secondary btn-lg">
                                <i class="fas fa-times"></i> Hủy
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")

    <script>
        $(document).ready(function () {
            $('#Avatar').on('change keyup', function () {
                var avatarPath = $(this).val().trim();
                if (avatarPath) {
                    $('#PreviewAvatar').attr('src', avatarPath);
                    $('#AvatarPreview').show();
                } else {
                    $('#AvatarPreview').hide();
                }
            });
        });

        function BrowseServer(field) {
            var finder = new CKFinder();
            finder.selectActionFunction = function (fileUrl) {
                document.getElementById(field).value = fileUrl;
                $('#' + field).trigger('change');
            };
            finder.popup();
        }
    </script>
}

<style>
    .form-label {
        font-weight: 600;
        color: #333;
    }

    .card {
        border: none;
        box-shadow: 0 0.15rem 1.75rem rgba(0, 0, 0, 0.1);
        border-radius: 0.5rem;
    }
</style>
