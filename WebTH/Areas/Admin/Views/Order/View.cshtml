@model WebTH.Models.EF.Order
@using PagedList;
@{
    ViewBag.Title = "Chi tiết đơn hàng";
}

@section naviheader {
    <ul class="navbar-nav">
        <li class="nav-item">
            <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
        </li>
        <li class="nav-item d-none d-sm-inline-block">
            <a href="/admin/home" class="nav-link">Trang chủ</a>
        </li>
        <li class="nav-item d-none d-sm-inline-block">
            <a href="#" class="nav-link">Chi tiết đơn hàng</a>
        </li>
    </ul>
}

<section class="content">

    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Chi tiết đơn hàng</h3>
            <a href="@Url.Action("ExportInvoice", "Order", new { id = Model.Id })" target="_blank" class="btn btn-warning ml-2">
                <i class="fa fa-print"></i> Xuất hóa đơn
            </a>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Mã đơn hàng</label>
                        <p class="form-control" style="font-weight:bold; font-family: monospace;">@Model.Code</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Họ tên khách hàng</label>
                        <p class="form-control">@Model.CustomerName</p>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Tổng tiền</label>
                        <p class="form-control text-danger" style="font-weight: bold;">@WebTH.Common.Common.FormatNumber(Model.TotalAmount, 0) đ</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Số điện thoại</label>
                        <p class="form-control">@Model.Phone</p>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Ngày tạo</label>
                        <p class="form-control">@Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Email</label>
                        <p class="form-control">@Model.Email</p>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Trạng thái đơn hàng</label>

                        @if (Model.DeliveryAttempts > 0)
                        {
                            <div class="text-danger mb-1" style="font-size: 13px; font-weight: bold;">
                                <i class="fa fa-warning"></i> Đã giao thất bại: @Model.DeliveryAttempts / 3 lần
                            </div>
                        }

                        <div class="form-control" style="border: none; padding-left: 0;">
                            @switch (Model.Status)
                            {
                                case 1:<span class="badge badge-warning" style="font-size:14px; padding:8px;">1. Đã đặt hàng (Chờ duyệt)</span> break;
                                case 2: <span class="badge badge-info" style="font-size:14px; padding:8px;">2. Đã duyệt (Chờ phân công)</span> break;
                                case 3: <span class="badge badge-primary" style="font-size:14px; padding:8px;">3. Shipper đã nhận đơn</span> break;
                                case 4: <span class="badge badge-primary" style="font-size:14px; padding:8px;">4. Shipper đang đi giao</span> break;
                                case 5: <span class="badge badge-success" style="font-size:14px; padding:8px;">5. Giao thành công</span> break;
                                case 6: <span class="badge badge-danger" style="font-size:14px; padding:8px;">6. Giao thất bại</span> break;
                                case 7: <span class="badge badge-secondary" style="font-size:14px; padding:8px;">7. Đã hủy</span> break;
                                default:<span class="badge badge-dark" style="font-size:14px; padding:8px;">Không xác định</span>break;
                            }
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    @if (!string.IsNullOrEmpty(Model.ShipperId) && ViewBag.ShipperName != null)
                    {
                        <div class="form-group">
                            <label>Shipper phụ trách</label>
                            <p class="form-control text-primary" style="font-weight: bold;">
                                <i class="fa fa-motorcycle"></i> @ViewBag.ShipperName
                            </p>
                        </div>
                    }
                </div>
            </div>

            <hr />

            <div class="row">
                <div class="col-12">
                    <h4 class="mb-3"><i class="fa fa-shopping-basket"></i> Danh sách sản phẩm</h4>
                </div>
                <div class="col-12">
                    @Html.Action("Partial_SanPham", "Order", new { id = Model.Id })
                </div>

                @if (Model.Status == 2 && ViewBag.ShipperList != null)
                {
                    <div class="col-12">
                        <div class="card card-warning mt-3">
                            <div class="card-header"><h3 class="card-title"><i class="fa fa-motorcycle"></i> Phân công Shipper</h3></div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-8">
                                        <div class="form-group mb-0">
                                            @Html.DropDownList("ddlShipper", (SelectList)ViewBag.ShipperList, "--- Chọn Shipper phụ trách ---", new { @class = "form-control", @id = "ddlShipper" })
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <button class="btn btn-primary btn-block" onclick="assignShipper(@Model.Id)">
                                            Giao đơn này
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @if (Model.Status == 6 && Model.DeliveryAttempts < 3)
                {
                    <div class="col-12">
                        <div class="card card-danger mt-3" style="border: 2px dashed #dc3545;">
                            <div class="card-body text-center">
                                <h4 class="text-danger"><i class="fa fa-refresh"></i> Đơn hàng đang bị khóa do giao thất bại!</h4>
                                <p>Số lần thất bại: <strong>@Model.DeliveryAttempts/3</strong>. Bạn có muốn mở khóa để phân công lại cho Shipper khác đi giao không?</p>
                                <button class="btn btn-danger btn-lg mt-2" onclick="retryDelivery(@Model.Id)">
                                    <i class="fa fa-unlock"></i> Mở khóa & Cho phép giao lại
                                </button>
                            </div>
                        </div>
                    </div>
                }

            </div>
        </div>
    </div>
</section>
@section scripts{
    <script>
        function assignShipper(orderId)
        {
            var shipperId = $('#ddlShipper').val();
            if (!shipperId) {
                alert('Vui lòng chọn 1 Shipper!'); return;
            }

            // Đổi text button để tránh click nhiều lần
            $(event.target).prop('disabled', true).text('Đang phân công...');

            $.post('/Admin/Order/AssignShipper', { id: orderId, shipperId: shipperId }, function (res) {
                if (res.success) {
                    alert(res.msg);
                    location.reload();
                } else {
                    alert(res.msg);
                    $(event.target).prop('disabled', false).text('Giao đơn này');
                }
            });
        }

        function retryDelivery(orderId)
        {
            if (confirm("Bạn có chắc chắn muốn mở khóa và yêu cầu giao lại đơn hàng này?")) {
                $.post('/Admin/Order/RetryDelivery', { id: orderId }, function (res) {
                    if (res.success) {
                        alert(res.msg);
                        location.reload();
                    } else {
                        alert(res.msg);
                    }
                });
            }
        }


    </script>

}