@model IEnumerable<WebTH.Models.EF.ProductCategory>

@if (Model != null && Model.Any())
{
    <section class="section-ourmenu bg2-pattern p-t-115 p-b-120">
        <div class="container">
            <div class="title-section-ourmenu t-center m-b-40">
                <span class="tit2-copy t-center" style="color: #666; font-style: italic; letter-spacing: 2px;"> Khám phá </span>
                <h3 class="tit5 t-center m-t-10" style="font-size: 2.8rem; color: #222; font-weight: 700; letter-spacing: 1px;">Sản Phẩm</h3>
                <div style="width: 60px; height: 3px; background: linear-gradient(to right, #d32f2f, #f57c00); margin: 15px auto;"></div>
            </div>
            <div class="row" style="margin-bottom: 15px;">
                @foreach (var item in Model)
                {
                    <div class="col-md-4" style="margin-bottom: 30px;">
                        <div class="item-ourmenu bo-rad-10 hov-img-zoom pos-relative transition-all" 
                             style="overflow: hidden; box-shadow: 0 5px 20px rgba(0,0,0, 0.1); border-radius: 12px; transition: all 0.3s ease;">
                            
                            <div style="position: relative; overflow: hidden; height: 280px; background: #f5f5f5;">
                                <img src="@Url.Content("~/" + (item.Icon ?? ""))" 
                                     alt="@item.Title" 
                                     style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease;" />
                                
                                <!-- Overlay effect -->
                                <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; 
                                           background: rgba(0,0,0,0.3); opacity: 0; transition: opacity 0.3s ease;" 
                                     class="overlay-dark"></div>
                            </div>

                            <a href="@Url.Content("~/" + (item.Alias ?? ""))" 
                               class="btn2 flex-c-m txt5 ab-c-m size7" 
                               style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); 
                                      background: rgba(211, 47, 47, 0.9); color: white; padding: 12px 30px; 
                                      border-radius: 25px; font-weight: 600; letter-spacing: 0.5px;
                                      z-index: 10; transition: all 0.3s ease; white-space: nowrap;">
                                @item.Title
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    <style>
        .item-ourmenu {
            cursor: pointer;
        }
        
        .item-ourmenu:hover {
            box-shadow: 0 12px 35px rgba(0,0,0, 0.18) !important;
            transform: translateY(-5px);
        }
        
        .item-ourmenu:hover img {
            transform: scale(1.12);
        }
        
        .item-ourmenu:hover .overlay-dark {
            opacity: 1 !important;
        }
        
        .item-ourmenu:hover a {
            background: rgba(211, 47, 47, 1) !important;
            box-shadow: 0 5px 15px rgba(211, 47, 47, 0.4);
            transform: translate(-50%, -50%) scale(1.08) !important;
        }
        
        .transition-all {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
    </style>
}