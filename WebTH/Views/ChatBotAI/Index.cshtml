
@{
    ViewBag.Title = "Trò chuyện với AI";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .chatbot-container {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        padding: 40px 20px;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
       }

    .chatbot-header {
        text-align: center;
        color: #fff;
        margin-bottom: 40px;
        animation: fadeInDown 0.6s ease;
    }

    .chatbot-header h1 {
        font-size: 2.5rem;
        font-weight: 700;
        margin: 0;
        text-shadow: 0 2px 10px rgba(0,0,0,0.2);
    }

    .chatbot-header p {
        font-size: 1rem;
        font-weight: 300;
        margin-top: 10px;
        opacity: 0.95;
    }

    .wrapper-chat {
        max-width: 900px;
        margin: 0 auto;
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.3);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        height: 600px;
        animation: fadeInUp 0.6s ease 0.2s backwards;
    }

    .chat-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: #fff;
        padding: 20px;
        text-align: center;
        border-bottom: 3px solid rgba(255,255,255,0.1);
    }

    .chat-header-title {
        font-size: 1.3rem;
        font-weight: 600;
        margin: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    .chat-header-title .icon {
        font-size: 1.5rem;
    }

    .chat-box {
        flex: 1;
        padding: 20px;
        overflow-y: auto;
        background-color: #f8f9fa;
    }

    .chat-box::-webkit-scrollbar {
        width: 8px;
    }

    .chat-box::-webkit-scrollbar-track {
        background: #f1f1f1;
    }

    .chat-box::-webkit-scrollbar-thumb {
        background: #667eea;
        border-radius: 4px;
    }

    .chat-box::-webkit-scrollbar-thumb:hover {
        background: #764ba2;
    }

    .message-wrapper {
        display: flex;
        margin-bottom: 15px;
        animation: fadeInMessage 0.3s ease;
    }

    .message-wrapper.user {
        justify-content: flex-end;
    }

    .message-wrapper.bot {
        justify-content: flex-start;
    }

    .message {
        max-width: 70%;
        padding: 12px 16px;
        border-radius: 15px;
        word-wrap: break-word;
        font-size: 0.95rem;
        line-height: 1.5;
        position: relative;
        animation: slideIn 0.3s ease;
    }

    .user-message {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: #fff;
        border-bottom-right-radius: 0;
        box-shadow: 0 3px 10px rgba(102, 126, 234, 0.3);
    }

    .bot-message {
        background-color: #e8ecf1;
        color: #333;
        border-bottom-left-radius: 0;
        box-shadow: 0 2px 6px rgba(0,0,0,0.05);
    }

    .typing {
        display: flex;
        align-items: center;
        gap: 5px;
        padding: 12px 16px;
        background-color: #e8ecf1;
        border-radius: 15px;
        border-bottom-left-radius: 0;
        width: fit-content;
    }

    .typing span {
        display: inline-block;
        background-color: #667eea;
        border-radius: 50%;
        width: 8px;
        height: 8px;
        animation: bounce 1.4s infinite ease-in-out;
    }

    .typing span:nth-child(1) {
        animation-delay: 0s;
    }

    .typing span:nth-child(2) {
        animation-delay: 0.2s;
    }

    .typing span:nth-child(3) {
        animation-delay: 0.4s;
    }

    @@keyframes bounce {
        0%, 80%, 100% {
            transform: translateY(0);
        }
        40% {
            transform: translateY(-8px);
        }
    }

    @@keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeInMessage {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }

    @@keyframes slideIn {
        from {
            transform: scale(0.95);
            opacity: 0;
        }
        to {
            transform: scale(1);
            opacity: 1;
        }
    }

    .chat-input-area {
        display: flex;
        gap: 12px;
        padding: 15px 20px;
        background: #fff;
        border-top: 1px solid #e0e0e0;
        align-items: flex-end;
    }

    .message-input-wrapper {
        flex: 1;
        display: flex;
        align-items: center;
        background: #f0f0f0;
        border-radius: 25px;
        padding: 5px 15px;
        transition: all 0.3s ease;
        border: 2px solid transparent;
    }

    .message-input-wrapper:focus-within {
        background: #fff;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }

    #message {
        flex: 1;
        border: none;
        background: transparent;
        outline: none;
        font-size: 0.95rem;
        font-family: inherit;
        resize: none;
        max-height: 100px;
    }

    .char-count {
        font-size: 0.75rem;
        color: #999;
        margin-left: 8px;
        white-space: nowrap;
    }

    #sendBtn {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        color: #fff;
        padding: 12px 28px;
        border-radius: 25px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        font-size: 0.95rem;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
        display: flex;
        align-items: center;
        gap: 8px;
        min-width: 100px;
        justify-content: center;
    }

    #sendBtn:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
    }

    #sendBtn:active:not(:disabled) {
        transform: translateY(0);
    }

    #sendBtn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        color: #999;
        text-align: center;
    }

    .empty-state-icon {
        font-size: 3rem;
        margin-bottom: 15px;
        opacity: 0.5;
    }

    .empty-state-text {
        font-size: 1rem;
        font-weight: 500;
    }

    @@media (max-width: 768px) {
        .wrapper-chat {
            height: 500px;
            border-radius: 15px;
        }

        .message {
            max-width: 85%;
        }

        .chatbot-header h1 {
            font-size: 1.8rem;
        }

        .chat-input-area {
            flex-direction: column;
            gap: 10px;
        }

        #sendBtn {
            width: 100%;
        }
    }
</style>

<div class="chatbot-container">
    <div class="chatbot-header">
        <h1>💬 AI Assistant</h1>
        <p>Đặt câu hỏi và nhận trợ giúp tức thì từ AI</p>
    </div>

    <div class="wrapper-chat">
        <div class="chat-header">
            <h3 class="chat-header-title">
                <span class="icon">🤖</span>
                Chat với AI được hỗ trợ bởi Groq
            </h3>
        </div>

        <div id="chat-container" class="chat-box">
            <div class="empty-state">
                <div class="empty-state-icon">💭</div>
                <div class="empty-state-text">Bắt đầu cuộc trò chuyện của bạn</div>
            </div>
        </div>

        <div class="chat-input-area">
            <div class="message-input-wrapper">
                <textarea id="message" rows="1" placeholder="Nhập tin nhắn của bạn (Shift+Enter để xuống dòng)..."></textarea>
                <span class="char-count"><span id="char-count">0</span>/500</span>
            </div>
            <button id="sendBtn" type="button">
                <span>➤</span>
                <span>Gửi</span>
            </button>
        </div>
    </div>
</div>


@section scripts {
    <script>
        let isLoading = false;
        let firstMessageSent = false;
        const MAX_CHAR = 500;

        // Character counter
        $('#message').on('input', function() {
            const count = $(this).val().length;
            $('#char-count').text(count);
            
            // Auto-grow textarea
            if (this.scrollHeight <= 100) {
                this.style.height = 'auto';
                this.style.height = Math.min(this.scrollHeight, 100) + 'px';
            }
        });

        // Clear empty state
        function clearEmptyState() {
            if (!firstMessageSent) {
                $('#chat-container').empty();
                firstMessageSent = true;
            }
        }

        // Send message handler
        function sendMessage() {
            var userMessage = $('#message').val().trim();
            if (!userMessage || isLoading) return;
            if (userMessage.length > MAX_CHAR) {
                alert('Tin nhắn quá dài (tối đa ' + MAX_CHAR + ' ký tự)');
                return;
            }

            clearEmptyState();

            // Add user message
            const userMessageEl = $('<div class="message-wrapper user"><div class="message user-message"></div></div>');
            userMessageEl.find('.message').text(userMessage);
            $('#chat-container').append(userMessageEl);
            $('#message').val('').css('height', 'auto');
            $('#char-count').text('0');
            $('#chat-container').scrollTop($('#chat-container')[0].scrollHeight);

            // Disable button and show loading
            isLoading = true;
            $('#sendBtn').prop('disabled', true).css('opacity', '0.7');

            // Show typing indicator
            const typingEl = $('<div class="message-wrapper bot"><div class="typing"><span></span><span></span><span></span></div></div>');
            $('#chat-container').append(typingEl);
            $('#chat-container').scrollTop($('#chat-container')[0].scrollHeight);

            // Request to AI
            $.ajax({
                url: '/ChatBotAI/AskAI',
                type: 'POST',
                data: { message: userMessage },
                success: function (res) {
                    typingEl.remove();
                    typeBotReply(res.reply);
                },
                error: function (xhr, status, error) {
                    typingEl.remove();
                    const errorMsg = 'Lỗi kết nối. Vui lòng thử lại.';
                    typeBotReply(errorMsg);
                },
                complete: function() {
                    isLoading = false;
                    $('#sendBtn').prop('disabled', false).css('opacity', '1');
                }
            });
        }

        // Send button click
        $('#sendBtn').click(function () {
            sendMessage();
        });

        // Send with Enter key (Shift+Enter for newline)
        $('#message').keydown(function (e) {
            if (e.which === 13) {
                if (e.shiftKey) {
                    return; // Allow Shift+Enter for newline
                } else {
                    e.preventDefault();
                    sendMessage();
                }
            }
        });

        // Type bot reply with effect
        function typeBotReply(text) {
            const container = $('<div class="message-wrapper bot"><div class="message bot-message"></div></div>');
            const messageEl = container.find('.message');
            $('#chat-container').append(container);
            $('#chat-container').scrollTop($('#chat-container')[0].scrollHeight);

            let i = 0;
            const speed = 15;
            const displayText = [];

            function type() {
                if (i < text.length) {
                    const char = text[i];
                    if (char === '\n') {
                        displayText.push('<br>');
                    } else {
                        displayText.push(escapeHtml(char));
                    }
                    messageEl.html(displayText.join(''));
                    i++;
                    $('#chat-container').scrollTop($('#chat-container')[0].scrollHeight);
                    setTimeout(type, speed);
                }
            }

            type();
        }

        // Escape HTML to prevent XSS
        function escapeHtml(text) {
            const map = {
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                '"': '&quot;',
                "'": '&#039;'
            };
            return text.replace(/[&<>"']/g, m => map[m]);
        }

        // Focus on textarea when page loads
        $(function() {
            $('#message').focus();
        });
    </script>
}
