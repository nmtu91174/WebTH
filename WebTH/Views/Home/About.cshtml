@{
    ViewBag.Title = "Về chúng tôi";
}

<style>
    /* About Page Styles */
    .about-banner {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 80px 0;
        color: white;
        text-align: center;
    }

    .about-banner h1 {
        font-size: 48px;
        font-weight: 700;
        margin-bottom: 20px;
    }

    .about-content {
        padding: 60px 0;
    }

    .about-intro {
        max-width: 800px;
        margin: 0 auto 60px;
        text-align: center;
    }

    .about-intro h2 {
        font-size: 32px;
        font-weight: 700;
        color: #222;
        margin-bottom: 20px;
    }

    .about-intro p {
        font-size: 16px;
        color: #666;
        line-height: 1.8;
        margin-bottom: 0;
    }

    .about-values {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 40px;
        max-width: 1200px;
        margin: 60px auto;
        padding: 0 20px;
    }

    .value-card {
        background: white;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        text-align: center;
        transition: all 0.3s ease;
    }

    .value-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.12);
    }

    .value-icon {
        width: 70px;
        height: 70px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 32px;
        margin: 0 auto 20px;
    }

    .value-card h3 {
        font-size: 20px;
        font-weight: 700;
        color: #222;
        margin-bottom: 15px;
    }

    .value-card p {
        font-size: 14px;
        color: #666;
        line-height: 1.6;
        margin: 0;
    }

    .story-section {
        background: #f9f9f9;
        padding: 60px 0;
        margin: 60px 0;
    }

    .story-wrapper {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: center;
    }

    .story-content h2 {
        font-size: 32px;
        font-weight: 700;
        color: #222;
        margin-bottom: 20px;
    }

    .story-content p {
        font-size: 14px;
        color: #666;
        line-height: 1.8;
        margin-bottom: 15px;
    }

    .story-image {
        width: 100%;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    }

    .story-image img {
        width: 100%;
        height: auto;
        object-fit: cover;
    }

    .team-section {
        max-width: 1200px;
        margin: 60px auto;
        padding: 60px 20px;
    }

    .section-title {
        font-size: 32px;
        font-weight: 700;
        color: #222;
        text-align: center;
        margin-bottom: 50px;
    }

    .team-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 30px;
    }

    .team-member {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        text-align: center;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
    }

    .team-member:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.12);
    }

    .team-image {
        width: 100%;
        height: 200px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 60px;
    }

    .team-info {
        padding: 20px;
    }

    .team-info h4 {
        font-size: 16px;
        font-weight: 700;
        color: #222;
        margin: 0 0 5px 0;
    }

    .team-info p {
        font-size: 13px;
        color: #999;
        margin: 0;
    }

    .stats-section {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 60px 0;
        margin: 60px 0;
    }

    .stats-wrapper {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 40px;
        text-align: center;
    }

    .stat-item h3 {
        font-size: 40px;
        font-weight: 700;
        margin-bottom: 10px;
    }

    .stat-item p {
        font-size: 14px;
        opacity: 0.9;
        margin: 0;
    }

    .cta-section {
        max-width: 600px;
        margin: 60px auto;
        padding: 40px;
        background: #f9f9f9;
        border-radius: 12px;
        text-align: center;
    }

    .cta-section h2 {
        font-size: 28px;
        font-weight: 700;
        color: #222;
        margin-bottom: 15px;
    }

    .cta-section p {
        font-size: 14px;
        color: #666;
        margin-bottom: 25px;
    }

    .cta-btn {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 14px 40px;
        border: none;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        cursor: pointer;
        display: inline-block;
        transition: all 0.3s ease;
    }

    .cta-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(102, 126, 234, 0.3);
    }

    @@media (max-width: 768px) {
        .about-values {
            grid-template-columns: 1fr;
        }

        .story-wrapper {
            grid-template-columns: 1fr;
        }

        .team-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .stats-wrapper {
            grid-template-columns: repeat(2, 1fr);
        }

        .about-banner h1 {
            font-size: 32px;
        }
    }
</style>

<section class="about-banner">
    <div class="container">
        <h1>@ViewBag.Title</h1>
        <p style="font-size: 18px; margin-top: 10px; color: white;">Chúng tôi cam kết cung cấp thức ăn chất lượng cao cho thú cưng yêu quý của bạn</p>
    </div>
</section>

<section class="about-content">
    <div class="about-intro">
        <h2>Chào mừng bạn đến với PetFood Online</h2>
        <p>
            PetFood Online là điểm đến tin cậy cho mọi nhu cầu thức ăn thú cưng của bạn. 
            Chúng tôi chuyên cung cấp các sản phẩm thức ăn chất lượng cao từ các thương hiệu nổi tiếng thế giới, 
            được lựa chọn kỹ lưỡng để đảm bảo sức khỏe và hạnh phúc của thú cưng yêu quý của bạn.
        </p>
    </div>

    <!-- Core Values -->
    <div class="about-values">
        <div class="value-card">
            <div class="value-icon">
                <i class="fa fa-star"></i>
            </div>
            <h3>Chất lượng</h3>
            <p>Chúng tôi chỉ bán các sản phẩm thức ăn thú cưng hàng đầu từ các thương hiệu uy tín trên thế giới.</p>
        </div>

        <div class="value-card">
            <div class="value-icon">
                <i class="fa fa-heart"></i>
            </div>
            <h3>Cải thiện sức khỏe</h3>
            <p>Mục tiêu của chúng tôi là cải thiện sức khỏe và chất lượng cuộc sống của thú cưng của bạn.</p>
        </div>

        <div class="value-card">
            <div class="value-icon">
                <i class="fa fa-handshake-o"></i>
            </div>
            <h3>Dịch vụ khách hàng</h3>
            <p>Đội ngũ hỗ trợ khách hàng 24/7 của chúng tôi luôn sẵn sàng giúp bạn.</p>
        </div>
    </div>
</section>

<!-- Story Section -->
<section class="story-section">
    <div class="story-wrapper">
        <div class="story-content">
            <h2>Câu chuyện của chúng tôi</h2>
            <p>
                PetFood Online được thành lập vào năm 2020 với mục đích duy nhất: 
                cung cấp thức ăn chất lượng cao cho thú cưng của bạn.
            </p>
            <p>
                Chúng tôi nhận thức rằng thú cưng của bạn không chỉ là một con vật trong nhà, 
                chúng là một phần của gia đình. Đó là lý do tại sao chúng tôi cam kết cung cấp những sản phẩm tốt nhất.
            </p>
            <p>
                Hôm nay, chúng tôi tự hào phục vụ hàng nghìn khách hàng hài lòng và tiếp tục phát triển 
                để mang lại giá trị tốt nhất cho bạn và thú cưng của bạn.
            </p>
        </div>
        <div class="story-image">
            <div style="width: 100%; height: 300px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 12px; display: flex; align-items: center; justify-content: center; color: white; font-size: 80px;">
                <i class="fa fa-paw"></i>
            </div>
        </div>
    </div>
</section>

<!-- Stats Section -->
<section class="stats-section">
    <div class="stats-wrapper">
        <div class="stat-item">
            <h3>50K+</h3>
            <p>Khách hàng hài lòng</p>
        </div>
        <div class="stat-item">
            <h3>100+</h3>
            <p>Loại sản phẩm</p>
        </div>
        <div class="stat-item">
            <h3>15+</h3>
            <p>Thương hiệu quốc tế</p>
        </div>
        <div class="stat-item">
            <h3>24/7</h3>
            <p>Hỗ trợ khách hàng</p>
        </div>
    </div>
</section>

<!-- Team Section -->
<section class="team-section">
    <h2 class="section-title">Đội ngũ của chúng tôi</h2>
    <div class="team-grid">
        <div class="team-member">
            <div class="team-image">
                <i class="fa fa-user"></i>
            </div>
            <div class="team-info">
                <h4>Nguyễn Văn An</h4>
                <p>Giám đốc điều hành</p>
            </div>
        </div>

        <div class="team-member">
            <div class="team-image">
                <i class="fa fa-user"></i>
            </div>
            <div class="team-info">
                <h4>Trần Thị Bạch</h4>
                <p>Giám đốc sản phẩm</p>
            </div>
        </div>

        <div class="team-member">
            <div class="team-image">
                <i class="fa fa-user"></i>
            </div>
            <div class="team-info">
                <h4>Lê Minh Châu</h4>
                <p>Trưởng nhóm bán hàng</p>
            </div>
        </div>

        <div class="team-member">
            <div class="team-image">
                <i class="fa fa-user"></i>
            </div>
            <div class="team-info">
                <h4>Phạm Quốc Tuấn</h4>
                <p>Quản lý hỗ trợ khách hàng</p>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="cta-section" style="margin-bottom: 80px;">
    <h2>Sẵn sàng chăm sóc thú cưng của bạn?</h2>
    <p>Khám phá bộ sưu tập đầy đủ các sản phẩm thức ăn thú cưng chất lượng cao của chúng tôi.</p>
    <a href="/menu/list" class="cta-btn">Khám phá sản phẩm</a>
</section>
