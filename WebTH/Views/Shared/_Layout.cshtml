<!DOCTYPE html>
<html>
<head>
    @{
        var pageTitle = ViewBag.Title as string;
        var fullTitle = string.IsNullOrWhiteSpace(pageTitle)
            ? "PetFood Online - Thức ăn chất lượng cho thú cưng của bạn"
            : pageTitle + " | PetFood Online";
        var seoDescription = ViewBag.SeoDescription as string;
        var seoKeywords = ViewBag.SeoKeywords as string;
        var currentController = (ViewContext.RouteData.Values["controller"] ?? string.Empty).ToString();
        var currentAction = (ViewContext.RouteData.Values["action"] ?? string.Empty).ToString();
        var isHomePage = currentController.Equals("Home", StringComparison.OrdinalIgnoreCase)
            && currentAction.Equals("Index", StringComparison.OrdinalIgnoreCase);
    }
    <title>@fullTitle</title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="@(string.IsNullOrWhiteSpace(seoDescription) ? "PetFood Online - thức ăn chất lượng cho thú cưng, nhiều lựa chọn cho chó và mèo." : seoDescription)" />
    
    @if (!string.IsNullOrWhiteSpace(seoKeywords))
    {
        <meta name="keywords" content="@seoKeywords" />
    }

    <link rel="icon" type="image/png" href="~/Content/assets/images/icons/22.png" />

    <link rel="stylesheet" type="text/css" href="~/Content/assets/vendor/bootstrap/css/bootstrap.min.css" />

    <link rel="stylesheet" type="text/css" href="~/Content/assets/fonts/font-awesome-4.7.0/css/font-awesome.min.css" />

    @*<link rel="stylesheet" type="text/css" href="~/Content/assets/fonts/themify/themify-icons.css" />*@

    <link rel="stylesheet" type="text/css" href="~/Content/assets/vendor/animate/animate.css" />

    <link rel="stylesheet" type="text/css" href="~/Content/assets/vendor/css-hamburgers/hamburgers.min.css" />

    <link rel="stylesheet" type="text/css" href="~/Content/assets/vendor/animsition/css/animsition.min.css" />

    <link rel="stylesheet" type="text/css" href="~/Content/assets/vendor/select2/select2.min.css" />

    <link rel="stylesheet" type="text/css" href="~/Content/assets/vendor/daterangepicker/daterangepicker.css" />

    <link rel="stylesheet" type="text/css" href="~/Content/assets/vendor/slick/slick.css" />

    <link rel="stylesheet" type="text/css" href="~/Content/assets/vendor/lightbox2/css/lightbox.min.css" />

    <link rel="stylesheet" type="text/css" href="~/Content/assets/css/util.css" />
    <link rel="stylesheet" type="text/css" href="~/Content/assets/css/main.css" />
    <link rel="stylesheet" type="text/css" href="~/Content/css/home-improvements.css" />

    <link href="~/Content/PagedList.css" rel="stylesheet" />
    
    <style>

        .account {
            display: inline-block;
            position: relative;
            min-width: 50px;
            padding-left: 20px;
            text-align: center;
            vertical-align: middle;
        }

            .account > a {
                display: block;
                color: #fff;
                font-weight: 400;
                height: 50px;
                line-height: 50px;
                background: #eceff6;
                border-radius: 50%;
            }

                .account > a > i {
                    margin-left: 8px;
                }

            .account:hover .account_selection {
                visibility: visible;
                opacity: 1;
                top: 100%;
            }

        .account_selection {
            display: block;
            position: absolute;
            left: -40px;
            top: 120%;
            margin: 0;
            width: 150px;
            background: #FFFFFF;
            visibility: hidden;
            opacity: 0;
            z-index: 1;
            box-shadow: 0 0 25px rgba(63, 78, 100, 0.15);
            -webkit-transition: opacity 0.3s ease;
            -moz-transition: opacity 0.3s ease;
            -ms-transition: opacity 0.3s ease;
            -o-transition: opacity 0.3s ease;
            transition: all 0.3s ease;
            border-radius: 10%;
        }

            .account_selection li {
                width: 100%;
                padding: 15px;
            }

                .account_selection li:first-child {
                    width: 100%;
                    padding-bottom: 0;
                }

                .account_selection li:last-child {
                    width: 100%;
                    padding-top: 0;
                }

                .account_selection li a {
                    width: 100%;
                    display: block;
                    color: #232530;
                    border-bottom: solid 1px #dddddd;
                    font-size: 14px;
                    -webkit-transition: all 0.3s ease;
                    -moz-transition: all 0.3s ease;
                    -ms-transition: all 0.3s ease;
                    -o-transition: all 0.3s ease;
                    transition: all 0.3s ease;
                }

                    .account_selection li a:hover {
                        color: #b5aec4;
                    }

                .account_selection li:last-child a {
                    border-bottom: none;
                }

                .account_selection li a i {
                    margin-right: 10px;
                }

                .account_selection li:first-child a {
                    display: inline-block;
                    max-width: 130px;
                    overflow: hidden;
                    white-space: nowrap;
                    text-overflow: ellipsis;
                    vertical-align: middle;
                }
    </style>
