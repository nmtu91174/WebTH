<body class="animsition @(isHomePage ? "home-bootstrap-pro" : string.Empty)">
    <div id="ajaxAntiForgeryForm" style="display:none;">
        @Html.AntiForgeryToken()
    </div>

    <header>
        <div class="wrap-menu-header gradient1 trans-0-4">
            <div class="container h-full">
                <div class="wrap_header trans-0-3">
                    <div class="logo">
                        <a href="/">
                            <img src="~/Content/assets/images/icons/22.png" alt="IMG-LOGO"
                                 data-logofixed="/Content/assets/images/icons/22.png" />
                        </a>
                    </div>

                    <div class="wrap_menu p-l-45 p-l-0-xl">
                        <nav class="menu">
                            @Html.Action("MenuTop", "Menu")
                        </nav>
                    </div>

                    <div class="social flex-w flex-l-m p-r-20">
                        @*<a href=""><i class="fa fa-user m-l-21 m-r-10" aria-hidden="true"></i></a>*@

                        <ul class="navbar_user">
                            @if (!Request.IsAuthenticated)
                            {
                                <li class="account">
                                    <a href="#"><i class="fa fa-user m-l-21 m-r-10" aria-hidden="true"></i></a>

                                    <ul class="account_selection">
                                        <li><a href="#"><i class="fa fa-user" aria-hidden="true"></i>Tên tài khoản</a></li>
                                        <li><a href="/account/login"><i class="fa fa-sign-in" aria-hidden="true"></i>Đăng nhập</a></li>
                                        <li><a href="/account/Register"><i class="fa fa-user-plus" aria-hidden="true"></i>Đăng ký</a></li>
                                    </ul>
                                </li>
                            }
                            else
                            {
                                <li class="account">
                                    <a href="#"><i class="fa fa-user m-l-21 m-r-10" aria-hidden="true"></i></a>

                                    <ul class="account_selection">
                                        <li><a href="#"><i class="fa fa-user" aria-hidden="true"></i>@User.Identity.Name</a></li>
                                        <li><a href="/account/profile"><i class="fa fa-sign-in" aria-hidden="true"></i>Hồ sơ</a></li>
                                        <li><a href="/wishlist/index"><i class="fa fa-sign-in" aria-hidden="true"></i>Sản phẩm yêu thích</a></li>
                                       
                                        <li><a href="javascript:document.getElementById('logOffForm').submit()"><i class="fa fa-user-plus" aria-hidden="true"></i>Đăng xuất</a></li>
                                    </ul>
                                </li>
                            }

                            <li class="checkout">
                                <a href="/gio-hang">
                                    <i class="fa fa-shopping-cart" aria-hidden="true"></i>
                                    <span id="checkout_items" class="checkout_items">0</span>
                                </a>
                            </li>
                        </ul>

                        @if (Request.IsAuthenticated)

                        {
                            <div style="display:none;">

                                @using (Html.BeginForm("LogOff", "Account", FormMethod.Post, new { @id = "logOffForm" }))
                                {
                                    @Html.AntiForgeryToken()
                                }
                            </div>

                        }
                        <button class="btn-show-sidebar m-l-33 trans-0-4"></button>
                    </div>
                </div>
            </div>
        </div>
    </header>




    <aside class="sidebar trans-0-4">
        <button class="btn-hide-sidebar ti-close color0-hov trans-0-4"></button>

        <ul class="menu-sidebar p-t-95 p-b-70">
            <li class="t-center m-b-13">
                <a href="/" class="txt19">Trang chủ</a>
            </li>
            <li class="t-center m-b-13">
                <a href="/thuc-an-cho-cun" class="txt19">Thức ăn chó</a>
            </li>
            <li class="t-center m-b-13">
                <a href="/thuc-an-cho-meo" class="txt19">Thức ăn mèo</a>
            </li>
            <li class="t-center m-b-13">
                <a href="/cau-chuyen-that-th" class="txt19">Về chúng tôi</a>
            </li>
            <li class="t-center m-b-13">
                <a href="/bai-tu-van" class="txt19">Hướng dẫn dinh dưỡng</a>
            </li>
            <li class="t-center m-b-33">
                <a href="/lien-he" class="txt19">Liên hệ</a>
            </li>

        </ul>

        <div class="gallery-sidebar t-center p-l-60 p-r-60 p-b-40">
            <h4 class="txt20 m-b-33">Sản phẩm bán chạy nhất</h4>

            @Html.Action("Partial_SidebarProducts", "Home")
        </div>
    </aside>

    @RenderBody()


