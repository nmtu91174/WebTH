@model IEnumerable<WebTH.Models.EF.Product>
@{
    ViewBag.Title = ViewBag.CategoryName ?? "Danh mục sản phẩm";
    var categoryName = ViewBag.CategoryName ?? "Danh mục sản phẩm";
    var products = Model ?? new List<WebTH.Models.EF.Product>();
    var saleCount = products.Count(p => p.PriceSale > 0);
    var inStockCount = products.Count(p => p.Quantity > 0);
    var avgPrice = products.Any()
        ? products.Average(p => p.PriceSale.HasValue && p.PriceSale.Value > 0 ? p.PriceSale.Value : p.Price)
        : 0;
}

<style>
    /* ========== Category Page Styles ========== */
    .category-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
    }

    .category-header {
        background: linear-gradient(135deg, #003d77 0%, #1e5ba8 100%);
        color: white;
        padding: 60px 20px;
        margin-bottom: 50px;
        border-radius: 12px;
        text-align: center;
    }

    .category-header h1 {
        font-size: 42px;
        font-weight: 700;
        margin: 0 0 15px 0;
        letter-spacing: 1px;
    }

    .category-header p {
        font-size: 16px;
        margin: 0;
        opacity: 0.95;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
        line-height: 1.6;
    }

    .products-wrapper {
        margin-bottom: 80px;
    }

    .category-metrics {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
        margin-bottom: 25px;
    }

    .metric-card {
        background: #fff;
        border: 1px solid #e9eef5;
        border-radius: 10px;
        padding: 14px 16px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

    .metric-card .value {
        font-size: 24px;
        font-weight: 700;
        color: #003d77;
        line-height: 1.2;
    }

    .metric-card .label {
        font-size: 12px;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.4px;
        margin-top: 4px;
    }

    .products-top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 1px solid #eee;
    }

    .products-count {
        font-size: 14px;
        color: #666;
        font-weight: 500;
    }

    .products-sort {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .products-sort label {
        font-size: 13px;
        color: #666;
        font-weight: 500;
        margin: 0;
    }

    .products-sort select {
        padding: 8px 12px;
        border: 1px solid #ddd;
        border-radius: 6px;
        font-size: 13px;
        cursor: pointer;
        min-width: 150px;
        transition: all 0.3s ease;
    }

    .products-sort select:hover {
        border-color: #003d77;
    }

    .products-sort select:focus {
        outline: none;
        border-color: #003d77;
        box-shadow: 0 0 0 3px rgba(0, 61, 119, 0.1);
    }

    .products-tools {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 12px;
        margin-bottom: 18px;
    }

    .products-search {
        position: relative;
    }

    .products-search i {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #9ca3af;
        font-size: 13px;
    }

    .products-search input {
        width: 100%;
        border: 1px solid #dbe3ef;
        border-radius: 8px;
        height: 40px;
        padding: 0 12px 0 36px;
        font-size: 14px;
    }

    .products-search input:focus {
        outline: none;
        border-color: #1e5ba8;
        box-shadow: 0 0 0 3px rgba(30, 91, 168, 0.1);
    }

    .quick-filters {
        display: flex;
        gap: 8px;
        align-items: center;
        flex-wrap: wrap;
    }

    .quick-filter {
        border: 1px solid #dbe3ef;
        background: #fff;
        color: #374151;
        border-radius: 999px;
        padding: 8px 12px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
    }

    .quick-filter.active {
        background: #003d77;
        color: #fff;
        border-color: #003d77;
    }

    .products-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 25px;
    }

    .product-card {
        background: #fff;
        border-radius: 12px;
        overflow: hidden;
        transition: all 0.3s ease;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        display: flex;
        flex-direction: column;
        position: relative;
        height: 100%;
    }

    .product-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15);
    }

    .product-image-wrapper {
        position: relative;
        overflow: hidden;
        background: #f5f5f5;
        aspect-ratio: 1;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .product-image-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .product-card:hover .product-image-wrapper img {
        transform: scale(1.05);
    }

    .stock-badge {
        position: absolute;
        top: 12px;
        right: 12px;
        z-index: 10;
        font-size: 11px;
        font-weight: 700;
        border-radius: 999px;
        padding: 6px 9px;
        color: white;
        background: #16a34a;
    }

    .stock-badge.out {
        background: #dc2626;
    }

    .product-action-btn {
        position: absolute;
        bottom: 15px;
        left: 50%;
        transform: translateX(-50%);
        background: #003d77;
        color: white;
        border: none;
        width: 50px;
        height: 50px;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        opacity: 0;
        visibility: hidden;
    }

    .product-card:hover .product-action-btn {
        opacity: 1;
        visibility: visible;
    }

    .product-action-btn:hover {
        background: #1e5ba8;
        transform: translateX(-50%) scale(1.1);
    }

    .product-action-btn i {
        font-size: 20px;
    }

    .wishlist-btn {
        position: absolute;
        top: 12px;
        left: 12px;
        width: 40px;
        height: 40px;
        background: rgba(255, 255, 255, 0.95);
        border: none;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        z-index: 10;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .wishlist-btn:hover {
        background: white;
        transform: scale(1.1);
    }

    .wishlist-btn i {
        font-size: 18px;
        color: #b9b4c7;
        transition: color 0.3s ease;
    }

    .wishlist-btn.active i {
        color: #fe4c50;
    }

    .product-info {
        padding: 20px;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }

    .product-title {
        font-size: 16px;
        font-weight: 600;
        color: #222;
        margin: 0 0 12px 0;
        line-height: 1.4;
        min-height: 38px;
        overflow: hidden;
        text-overflow: ellipsis;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .product-title a {
        color: #222;
        text-decoration: none;
        transition: color 0.3s ease;
    }

    .product-title a:hover {
        color: #003d77;
    }

    .product-category {
        font-size: 12px;
        color: #999;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 10px;
    }

    .product-pricing {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: auto;
        padding-top: 15px;
        border-top: 1px solid #eee;
    }

    .product-price {
        font-size: 20px;
        font-weight: 700;
        color: #003d77;
    }

    .product-original-price {
        font-size: 14px;
        color: #999;
        text-decoration: line-through;
    }

    .discount-badge {
        background: #fe4c50;
        color: white;
        font-size: 11px;
        font-weight: 700;
        padding: 4px 8px;
        border-radius: 4px;
        margin-left: auto;
    }

    .no-products-message {
        grid-column: 1 / -1;
        text-align: center;
        padding: 60px 20px;
        color: #999;
        font-size: 16px;
    }

    @@media (max-width: 768px) {
        .category-header h1 {
            font-size: 28px;
        }

        .category-metrics {
            grid-template-columns: 1fr;
        }

        .products-grid {
            grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        }

        .products-top-bar {
            flex-direction: column;
            gap: 15px;
            align-items: flex-start;
        }

        .products-tools {
            grid-template-columns: 1fr;
        }
    }
</style>

<!-- Category Header -->
<div class="category-header">
    <h1>@categoryName</h1>
    @if (!string.IsNullOrEmpty(ViewBag.CategoryDescription))
    {
        <p>@Html.Raw(ViewBag.CategoryDescription)</p>
    }
</div>

<!-- Products Section -->
<div class="category-container">
    <div class="products-wrapper">
        <div class="category-metrics">
            <div class="metric-card">
                <div class="value">@products.Count()</div>
                <div class="label">Tổng sản phẩm</div>
            </div>
            <div class="metric-card">
                <div class="value">@saleCount</div>
                <div class="label">Đang giảm giá</div>
            </div>
            <div class="metric-card">
                <div class="value">@WebTH.Common.Common.FormatNumber(avgPrice, 0)₫</div>
                <div class="label">Giá trung bình</div>
            </div>
        </div>

        <div class="products-tools">
            <div class="products-search">
                <i class="fa fa-search"></i>
                <input id="searchKeyword" type="text" placeholder="Tìm nhanh theo tên sản phẩm..." />
            </div>
            <div class="quick-filters">
                <button class="quick-filter active" data-filter="all">Tất cả</button>
                <button class="quick-filter" data-filter="sale">Giảm giá</button>
                <button class="quick-filter" data-filter="instock">Còn hàng (@inStockCount)</button>
            </div>
        </div>

        <!-- Top Bar with Count and Sort -->
        <div class="products-top-bar">
            <div class="products-count">
                <span id="productCount">@products.Count()</span> sản phẩm
            </div>
            <div class="products-sort">
                <label for="sortBy">Sắp xếp:</label>
                <select id="sortBy" class="products-sort-select">
                    <option value="newest">Mới nhất</option>
                    <option value="price-low">Giá: Thấp đến Cao</option>
                    <option value="price-high">Giá: Cao đến Thấp</option>
                    <option value="popular">Phổ biến nhất</option>
                </select>
            </div>
        </div>

        <!-- Products Grid -->
        @if (products.Any())
        {
            <div class="products-grid" id="productsGrid">
                @foreach (var item in products)
                {
                    var strImage = item.ProductImage?.FirstOrDefault(x => x.IsDefault)?.Image ?? "/Content/assets/images/no-image.jpg";
                    var isWishlist = item.Wishlists?.Any(x => x.UserName == User.Identity.Name) ?? false;
                    var discountPercent = 0;
                    if (item.PriceSale > 0 && item.Price > 0)
                    {
                        discountPercent = (int)((item.Price - item.PriceSale) / item.Price * 100);
                    }
                    var titleKey = (item.Title ?? string.Empty).ToLowerInvariant();
                    var effectivePrice = item.PriceSale.HasValue && item.PriceSale.Value > 0 ? item.PriceSale.Value : item.Price;
                    var isInStock = item.Quantity > 0;

                    <div class="product-card"
                         data-price="@item.Price"
                         data-effective-price="@effectivePrice"
                         data-sale-price="@item.PriceSale"
                         data-view-count="@item.ViewCount"
                         data-id="@item.Id"
                         data-title="@titleKey"
                         data-sale="@(item.PriceSale > 0 ? 1 : 0)"
                         data-stock="@(isInStock ? 1 : 0)">
                        <div class="product-image-wrapper">
                            <img src="@strImage" alt="@item.Title" />
                            <span class="stock-badge @(isInStock ? "" : "out")">@(isInStock ? "Còn hàng" : "Hết hàng")</span>
                            <a href="" class="product-action-btn btnAddToCart" data-id="@item.Id" title="Thêm vào giỏ hàng">
                                <i class="fa fa-shopping-cart"></i>
                            </a>
                            <button class="wishlist-btn @(isWishlist ? "active" : "")" data-id="@item.Id" data-product-id="@item.Id" title="Yêu thích">
                                <i class="fa fa-heart-o"></i>
                            </button>
                        </div>
                        <div class="product-info">
                            <div class="product-category">@categoryName</div>
                            <h3 class="product-title">
                                <a href="/chi-tiet/@item.Alias-p@(item.Id)">@item.Title</a>
                            </h3>
                            <div class="product-pricing">
                                @if (item.PriceSale > 0)
                                {
                                    <span class="product-price">@WebTH.Common.Common.FormatNumber(item.PriceSale, 0)₫</span>
                                    <span class="product-original-price">@WebTH.Common.Common.FormatNumber(item.Price, 0)₫</span>
                                    <span class="discount-badge">-@discountPercent%</span>
                                }
                                else
                                {
                                    <span class="product-price">@WebTH.Common.Common.FormatNumber(item.Price, 0)₫</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="no-products-message">
                <i class="fa fa-inbox" style="font-size: 48px; margin-bottom: 15px; opacity: 0.3;"></i>
                <p>Không có sản phẩm nào trong danh mục này.</p>
            </div>
        }
    </div>
</div>

@section scripts {
    <script>
        $(document).ready(function () {
            // Wishlist button toggle
            $('.wishlist-btn').on('click', function (e) {
                e.preventDefault();
                $(this).toggleClass('active');
            });

            // Cart button with feedback
            $('.btnAddToCart').on('click', function (e) {
                e.preventDefault();
                var btn = $(this);
                var originalHTML = btn.html();
                btn.html('<i class="fa fa-check"></i>');
                
                setTimeout(function () {
                    btn.html(originalHTML);
                }, 1500);
            });

            // Sort products
            function applyProductState() {
                var sortBy = $('#sortBy').val();
                var $grid = $('#productsGrid');
                var keyword = ($('#searchKeyword').val() || '').toLowerCase().trim();
                var quickFilter = $('.quick-filter.active').data('filter') || 'all';
                var $products = $grid.find('.product-card');
                var visibleProducts = [];

                $products.each(function () {
                    var $item = $(this);
                    var title = ($item.data('title') || '').toString();
                    var isSale = parseInt($item.data('sale')) === 1;
                    var isInStock = parseInt($item.data('stock')) === 1;

                    var matchKeyword = keyword === '' || title.indexOf(keyword) >= 0;
                    var matchQuickFilter = quickFilter === 'all'
                        || (quickFilter === 'sale' && isSale)
                        || (quickFilter === 'instock' && isInStock);

                    if (matchKeyword && matchQuickFilter) {
                        $item.show();
                        visibleProducts.push($item[0]);
                    } else {
                        $item.hide();
                    }
                });

                visibleProducts.sort(function (a, b) {
                    var aPrice = parseFloat($(a).data('effective-price'));
                    var bPrice = parseFloat($(b).data('effective-price'));
                    var aViews = parseInt($(a).data('view-count'));
                    var bViews = parseInt($(b).data('view-count'));
                    var aTitle = ($(a).data('title') || '').toString();
                    var bTitle = ($(b).data('title') || '').toString();

                    switch (sortBy) {
                        case 'price-low':
                            return aPrice - bPrice;
                        case 'price-high':
                            return bPrice - aPrice;
                        case 'popular':
                            return bViews - aViews;
                        case 'newest':
                            return parseInt($(b).data('id')) - parseInt($(a).data('id'));
                        default:
                            return aTitle.localeCompare(bTitle);
                    }
                });

                $.each(visibleProducts, function (index, product) {
                    $grid.append(product);
                });

                $('#productCount').text(visibleProducts.length);
            }

            $('#sortBy').on('change', applyProductState);
            $('#searchKeyword').on('input', applyProductState);
            $('.quick-filter').on('click', function () {
                $('.quick-filter').removeClass('active');
                $(this).addClass('active');
                applyProductState();
            });
        });
    </script>
}
