@{
    @*//var ldImage = Model.ProductImage?.FirstOrDefault(x => x.IsDefault && !string.IsNullOrEmpty(x.Image))?.Image
            //                            ?? Model.ProductImage?.FirstOrDefault(x => !string.IsNullOrEmpty(x.Image))?.Image
            //                            ?? "/Content/assets/images/placeholder.jpg";*@

            var ldImage = !string.IsNullOrEmpty(Model.Image)
            ? (Model.Image.StartsWith("/") ? Model.Image : "/Uploads/images/sanpham/" + Model.Image)
            : "/Content/assets/images/placeholder.jpg";


            var ldPrice = Model.PriceSale > 0 ? Model.PriceSale : Model.Price;
            var ldAvailability = "http://schema.org/InStock";
            var ldUrl = Request?.Url != null ? Request.Url.AbsoluteUri : Url.Action("Detail", "Products", new { id = Model.Id });
        }

        @* JSON-LD structured data for product *@
    @{
        var structuredData = new Dictionary<string, object>() {
        {"@context", "http://schema.org"},
        {"@type", "Product"},
        {"name", Model.Title ?? string.Empty},
        {"image", new[] { ldImage } },
        {"description", Model.Description ?? string.Empty},
        {"sku", Model.Id},
        {"offers", new Dictionary<string, object>() {
            {"@type", "Offer"},
            {"url", ldUrl},
            {"priceCurrency", "VND"},
            {"price", ldPrice},
            {"availability", ldAvailability}
        }}
    };
    }
    <script type="application/ld+json">
    @Html.Raw(System.Web.Helpers.Json.Encode(structuredData))
    </script>

    @section scripts {
        <script type="text/javascript" src="~/Content/assets/js/shop-detail.js"></script>
        <script>
            $(document).ready(function () {
                // Product Image Gallery
                $('.thumbnail-item').on('click', function () {
                    var imgSrc = $(this).data('src');
                    $('#mainProductImage').attr('src', imgSrc).fadeOut(100).fadeIn(300);

                    $('.thumbnail-item').removeClass('active');
                    $(this).addClass('active');
                });

                // Image Zoom on Main Image Click or Zoom Icon Click
                $('#mainProductImage, .zoom-icon').on('click', function (e) {
                    e.preventDefault();
                    var imgSrc = $('#mainProductImage').attr('src');

                    var modal = $('<div class="modal-zoom" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.85); z-index:9999; display:flex; align-items:center; justify-content:center;"><div style="position:relative;"><img src="' + imgSrc + '" style="max-width:90vh; max-height:90vh; border-radius:8px; box-shadow: 0 20px 60px rgba(0,0,0,0.3);"/><button style="position:absolute; top:15px; right:15px; background:white; border:none; padding:8px 14px; border-radius:8px; cursor:pointer; font-size:28px; color:#fe4c50; width:50px; height:50px; display:flex; align-items:center; justify-content:center; font-weight:bold; transition:all 0.2s ease;" onmouseover="this.style.background=\'#fe4c50\'; this.style.color=\'white\';" onmouseout="this.style.background=\'white\'; this.style.color=\'#fe4c50\';">&times;</button></div></div>');

                    $('body').append(modal);
                    modal.fadeIn(200);
                    $('body').css('overflow', 'hidden');

                    modal.on('click', function (e) {
                        if (e.target === this) {
                            $(this).fadeOut(200, function () { $(this).remove(); });
                            $('body').css('overflow', 'auto');
                        }
                    });

                    modal.find('button').on('click', function (e) {
                        e.stopPropagation();
                        modal.fadeOut(200, function () { $(this).remove(); });
                        $('body').css('overflow', 'auto');
                    });

                    $(document).on('keydown', function (e) {
                        if (e.keyCode === 27) {
                            modal.fadeOut(200, function () { $(this).remove(); });
                            $('body').css('overflow', 'auto');
                            $(document).off('keydown');
                        }
                    });
                });

                // Tab Navigation
                $('.tab-button').on('click', function () {
                    var tabName = $(this).data('tab');

                    // Remove active class
                    $('.tab-button').removeClass('active');
                    $('.tab-content').removeClass('active');

                    // Add active class
                    $(this).addClass('active');
                    $('#' + tabName).addClass('active');
                });

                //// Quantity Selector
                //$('.quantity_selector .plus').on('click', function () {
                //    var val = parseInt($('#quantity_value').text());
                //    $('#quantity_value').text(val + 1);
                //});

                //$('.quantity_selector .minus').on('click', function () {
                //    var val = parseInt($('#quantity_value').text());
                //    if (val > 1) {
                //        $('#quantity_value').text(val - 1);
                //    }
                //});

                // Wishlist Button
                $('.wishlist-btn').on('click', function () {
                    $(this).toggleClass('active');
                    var productId = $(this).data('id');

                    if ($(this).hasClass('active')) {
                        $(this).html('<i class="fa fa-heart"></i> Yêu thích');
                        // Send AJAX to add to wishlist
                        $.post('/Wishlist/AddToWishlist', { productId: productId }, function (result) {
                            console.log('Added to wishlist');
                        });
                    } else {
                        $(this).html('<i class="fa fa-heart-o"></i> Yêu thích');
                        // Send AJAX to remove from wishlist
                        $.post('/Wishlist/RemoveFromWishlist', { productId: productId }, function (result) {
                            console.log('Removed from wishlist');
                        });
                    }
                });

                // Share Button
                $('.share-btn').on('click', function () {
                    var productUrl = window.location.href;
                    var productTitle = $('.product-title-large').text();

                    var shareMenu = $('<div style="position:absolute; background:white; border-radius:10px; box-shadow:0 8px 25px rgba(0,0,0,0.15); padding:15px; min-width:200px; margin-top:10px; z-index:100; right:0;"><a href="https://www.facebook.com/sharer/sharer.php?u=' + productUrl + '" target="_blank" style="display:flex; align-items:center; gap:10px; padding:10px; border-radius:8px; color:#1877f2; text-decoration:none; transition:all 0.2s;" onmouseover="this.style.background=\'#f0f0f0\';" onmouseout="this.style.background=\'transparent\';"><i class="fa fa-facebook" style="font-size:20px;"></i> Facebook</a><a href="https://twitter.com/intent/tweet?url=' + productUrl + '&text=' + productTitle + '" target="_blank" style="display:flex; align-items:center; gap:10px; padding:10px; border-radius:8px; color:#1da1f2; text-decoration:none; transition:all 0.2s;" onmouseover="this.style.background=\'#f0f0f0\';" onmouseout="this.style.background=\'transparent\';"><i class="fa fa-twitter" style="font-size:20px;"></i> Twitter</a><a href="mailto:?subject=' + productTitle + '&body=' + productUrl + '" style="display:flex; align-items:center; gap:10px; padding:10px; border-radius:8px; color:#666; text-decoration:none; transition:all 0.2s;" onmouseover="this.style.background=\'#f0f0f0\';" onmouseout="this.style.background=\'transparent\';"><i class="fa fa-envelope" style="font-size:20px;"></i> Email</a><hr style="margin:5px 0;"><a style="display:flex; align-items:center; gap:10px; padding:10px; border-radius:8px; color:#666; text-decoration:none; cursor:pointer; transition:all 0.2s;" onmouseover="this.style.background=\'#f0f0f0\';" onmouseout="this.style.background=\'transparent\';"><i class="fa fa-link" style="font-size:20px;"></i> Copy Link</a></div>');

                    $(this).after(shareMenu);

                    shareMenu.find('a:last').on('click', function () {
                        var temp = $('<input>');
                        $('body').append(temp);
                        temp.val(productUrl).select();
                        document.execCommand('copy');
                        temp.remove();
                        alert('Link đã được sao chép!');
                    });

                    $(document).on('click', function (e) {
                        if (!$(e.target).closest('.share-btn, [style*="position:absolute"]').length) {
                            shareMenu.remove();
                        }
                    });
                });

                // Q&A Toggle Functionality
                $('.qa-question').on('click', function () {
                    var qaItem = $(this).closest('.qa-item');
                    qaItem.toggleClass('open');

                    // Close other open items
                    $('.qa-item.open').not(qaItem).removeClass('open');
                });

                // Tab Navigation with smooth scrolling
                $('.tab-button').on('click', function () {
                    var tabName = $(this).data('tab');

                    // Remove active class
                    $('.tab-button').removeClass('active');
                    $('.tab-content').removeClass('active');

                    // Add active class
                    $(this).addClass('active');
                    $('#' + tabName).addClass('active');

                    // Smooth scroll to tabs
                    $('html, body').animate({
                        scrollTop: $('.product-tabs').offset().top - 100
                    }, 300);
                });
            });
        </script>
    }
