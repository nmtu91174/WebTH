            // Filter and Sort Functions
            function filterAndSortProducts() {
                var $grid = $('#productsGrid');
                var $allProducts = $grid.find('.product-card');
                var displayedProducts = [];

                // Get filter values
                var selectedCategories = [];
                $('.category-filter:checked').each(function () {
                    selectedCategories.push($(this).data('category'));
                });

                var minPrice = parseInt($('#priceMin').val()) || 0;
                var maxPrice = parseInt($('#priceMax').val()) || 999999999;
                var onSaleOnly = $('#onSale').is(':checked');
                var sortBy = $('#sortBy').val() || $('#sortTop').val() || 'newest';

                // Filter products
                $allProducts.each(function () {
                    var $product = $(this);
                    var category = $product.data('category');
                    var price = parseInt($product.data('price'));
                    var salePrice = parseInt($product.data('sale-price'));
                    var hasDiscount = salePrice > 0;

                    var showCategory = selectedCategories.length === 0 || selectedCategories.includes(category);
                    var showPrice = price >= minPrice && price <= maxPrice;
                    var showSale = !onSaleOnly || hasDiscount;

                    if (showCategory && showPrice && showSale) {
                        $product.show();
                        displayedProducts.push($product);
                    } else {
                        $product.hide();
                    }
                });

                // Sort products
                displayedProducts.sort(function (a, b) {
                    var priceA = parseInt($(a).data('price'));
                    var priceB = parseInt($(b).data('price'));

                    switch (sortBy) {
                        case 'price-low':
                            return priceA - priceB;
                        case 'price-high':
                            return priceB - priceA;
                        default:
                            return 0;
                    }
                });

                // Reorder visible products
                $.each(displayedProducts, function (index, $product) {
                    $product.detach().appendTo($grid);
                });

                // Update product count
                $('#productCount').text(displayedProducts.length);

                // Show/hide no products message
                if (displayedProducts.length === 0) {
                    if ($('#noProductsMsg').length === 0) {
                        $grid.append('<div id="noProductsMsg" class="no-products-message" style="grid-column: 1/-1;"><i class="fa fa-search" style="font-size: 48px; margin-bottom: 15px; opacity: 0.3;"></i><p>Không tìm thấy sản phẩm phù hợp với bộ lọc của bạn.</p></div>');
                    }
                } else {
                    $('#noProductsMsg').remove();
                }
            }

            // Event listeners for filters
            $('.category-filter').on('change', filterAndSortProducts);
            $('#priceMin, #priceMax').on('change', filterAndSortProducts);
            $('#onSale').on('change', filterAndSortProducts);
            $('#sortBy, #sortTop').on('change', function () {
                $('#sortBy').val($(this).val());
                $('#sortTop').val($(this).val());
                filterAndSortProducts();
            });

            // Clear filters
            $('#clearFilters').on('click', function () {
                $('.category-filter').prop('checked', false);
                $('#priceMin').val('');
                $('#priceMax').val('');
                $('#onSale').prop('checked', false);
                $('#sortBy').val('newest');
                $('#sortTop').val('newest');
                filterAndSortProducts();
            });
        });
    </script>
