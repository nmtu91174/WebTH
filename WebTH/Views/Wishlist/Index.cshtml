<script>
    function removeFromWishlist(productId) {
        if (!confirm('Bạn chắc chắn muốn xóa sản phẩm này?')) return;

        var token = $('input[name="__RequestVerificationToken"]').val();
        $.ajax({
            url: '/Wishlist/PostDeleteWishlist',
            type: 'POST',
            data: { ProductId: productId, __RequestVerificationToken: token },
            success: function (rs) {
                if (rs.Success) {
                    location.reload(); // Reload lại trang để cập nhật danh sách
                } else {
                    alert(rs.Message || 'Xóa thất bại!');
                }
            },
            error: function () {
                alert('Có lỗi xảy ra, vui lòng thử lại!');
            }
        });
    }

    function addToCart(productId) {
        var token = $('input[name="__RequestVerificationToken"]').val();
        $.ajax({
            url: '/shoppingcart/addtocart',
            type: 'POST',
            data: { id: productId, quantity: 1, __RequestVerificationToken: token },
            success: function (rs) {
                if (rs.Success) {
                    $('#checkout_items').html(rs.Count);
                    alert('Đã thêm vào giỏ hàng!');
                } else {
                    alert(rs.msg || 'Thêm vào giỏ thất bại!');
                }
            },
            error: function () {
                alert('Có lỗi xảy ra, vui lòng thử lại!');
            }
        });
    }
</script>