@model IEnumerable<WebTH.Models.VetRecommendation>

@{
    ViewBag.Title = "Khuyến Cáo Từ Bác Sĩ Thú Y";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <h1 class="mb-4">
                <i class="fa fa-lightbulb"></i> Khuyến Cáo Từ Bác Sĩ Thú Y
            </h1>
            @if (ViewBag.Product != null)
            {
                <div class="alert alert-info">
                    <strong>Sản phẩm:</strong> @ViewBag.Product.Title
                </div>
            }
        </div>
    </div>

    @if (Model.Count() > 0)
    {
        <div class="row">
            @foreach (var rec in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 border-left-primary" style="border-left: 4px solid #667eea;">
                        <!-- Vet Clinic Header -->
                        <div class="card-header bg-light">
                            <h5 class="mb-0">
                                <a href="@Url.Action("Details", "Vet", new { id = rec.VetClinic.Id })">
                                    @rec.VetClinic.ClinicName
                                </a>
                            </h5>
                            @if (rec.VetClinic.IsVerified)
                            {
                                <small class="text-success">
                                    <i class="fa fa-check-circle"></i> Đã xác minh
                                </small>
                            }
                        </div>

                        <div class="card-body">
                            <!-- Doctor Info -->
                            @if (rec.VetDoctor != null)
                            {
                                <p class="small">
                                    <strong><i class="fa fa-user-md"></i> Bác Sĩ:</strong> @rec.VetDoctor.DoctorName
                                </p>
                                if (!string.IsNullOrEmpty(rec.VetDoctor.Specialization))
                                {
                                    <p class="small text-primary">@rec.VetDoctor.Specialization</p>
                                }
                            }

                            <!-- Recommendation Level -->
                            @{
                                string badgeColor = rec.RecommendationLevel == 3 ? "danger" :
                                                   rec.RecommendationLevel == 2 ? "warning" : "info";
                                string levelText = rec.RecommendationLevel == 3 ? "Cần Thiết" :
                                                  rec.RecommendationLevel == 2 ? "Khuyến Cáo Mạnh" : "Khuyến Cáo";
                            }
                            <span class="badge badge-@badgeColor">@levelText</span>

                            <!-- Pet Info -->
                            <div class="mt-2 mb-2">
                                @if (!string.IsNullOrEmpty(rec.PetType))
                                {
                                    <span class="badge badge-info">
                                        <i class="fa fa-paw"></i> @rec.PetType
                                    </span>
                                }
                                @if (!string.IsNullOrEmpty(rec.PetAgeRange))
                                {
                                    <span class="badge badge-light border">
                                        <i class="fa fa-calendar"></i> @rec.PetAgeRange
                                    </span>
                                }
                                @if (!string.IsNullOrEmpty(rec.HealthCondition))
                                {
                                    <span class="badge badge-warning">
                                        <i class="fa fa-heartbeat"></i> @rec.HealthCondition
                                    </span>
                                }
                            </div>

                            <!-- Recommendation Reason -->
                            <p class="card-text mt-3">
                                <strong>Lý Do Khuyến Cáo:</strong><br/>
                                @rec.ReccommendationReason
                            </p>

                            <!-- Meta Info -->
                            <p class="small text-muted mt-3">
                                <i class="fa fa-calendar"></i> @rec.CreatedDate.ToString("dd/MM/yyyy") 
                                | <i class="fa fa-eye"></i> @rec.TotalReferences tham khảo
                            </p>

                            <!-- Clinic Rating & Contact -->
                            <div class="mt-3 pt-3 border-top">
                                <p class="small mb-2">
                                    <strong><i class="fa fa-star text-warning"></i> @rec.VetClinic.AverageRating.ToString("F1")</strong>
                                    <small class="text-muted">(@rec.VetClinic.TotalRecommendations khuyến cáo)</small>
                                </p>
                                <p class="small mb-2">
                                    <i class="fa fa-phone"></i> @rec.VetClinic.Phone
                                </p>
                                <p class="small mb-0">
                                    <i class="fa fa-map-marker"></i> @rec.VetClinic.District, @rec.VetClinic.City
                                </p>
                            </div>
                        </div>

                        <div class="card-footer bg-light">
                            <a href="@Url.Action("Details", "Vet", new { id = rec.VetClinic.Id })" 
                               class="btn btn-sm btn-primary btn-block">
                                <i class="fa fa-hospital-o"></i> Xem Phòng Khám
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Statistics -->
        <div class="row mt-4">
            <div class="col-12">
                <div class="card bg-light">
                    <div class="card-body">
                        <h6 class="card-title">Thống Kê Khuyến Cáo</h6>
                        <div class="row text-center">
                            <div class="col-4">
                                <h3 class="text-primary">@Model.Count()</h3>
                                <small>Tổng khuyến cáo</small>
                            </div>
                            <div class="col-4">
                                <h3 class="text-danger">@Model.Count(r => r.RecommendationLevel == 3)</h3>
                                <small>Cần Thiết</small>
                            </div>
                            <div class="col-4">
                                <h3 class="text-success">@Model.Sum(r => r.TotalReferences)</h3>
                                <small>Tổng tham khảo</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-12">
                <div class="alert alert-warning text-center">
                    <i class="fa fa-exclamation-triangle"></i> Chưa có khuyến cáo nào từ bác sĩ thú y cho sản phẩm này.
                </div>
            </div>
        </div>
    }
</div>

