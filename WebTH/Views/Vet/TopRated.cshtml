@model IEnumerable<WebTH.Models.VetClinic>

@{
    ViewBag.Title = "Top Phòng Khám Thú Y";
    var clinics = new List<WebTH.Models.VetClinic>();
    if (Model != null)
    {
        clinics.AddRange(Model);
    }
}

<section class="top-vet-hero">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <span class="hero-badge"><i class="fa fa-trophy mr-1"></i> Xếp hạng uy tín</span>
                <h1>Top Phòng Khám Thú Y Được Đánh Giá Cao</h1>
                <p>Danh sách các phòng khám có điểm đánh giá và mức độ khuyến nghị nổi bật từ cộng đồng và bác sĩ thú y.</p>
            </div>
            <div class="col-lg-4 text-lg-right mt-3 mt-lg-0">
                <a href="@Url.Action("Index", "Vet")" class="btn btn-light btn-lg">
                    <i class="fa fa-arrow-left mr-1"></i> Quay lại danh sách
                </a>
            </div>
        </div>
    </div>
</section>

<section class="container my-4">
    @if (clinics.Count > 0)
    {
        <div class="row">
            @for (int i = 0; i < clinics.Count; i++)
            {
                var clinic = clinics[i];
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card top-vet-card h-100">
                        <div class="rank-badge">#@(i + 1)</div>
                        <div class="card-body d-flex flex-column">
                            <h5 class="mb-2">
                                <a class="clinic-link" href="@Url.Action("Details", "Vet", new { id = clinic.Id })">@clinic.ClinicName</a>
                            </h5>
                            <div class="mb-3">
                                <span class="badge badge-warning"><i class="fa fa-star mr-1"></i>@clinic.AverageRating.ToString("F1")</span>
                                <span class="badge badge-info ml-1">@clinic.TotalRecommendations khuyến cáo</span>
                            </div>
                            <p class="text-muted small mb-2">
                                <i class="fa fa-map-marker mr-1"></i>@clinic.Address
                            </p>
                            <p class="text-muted small mb-3">
                                <i class="fa fa-phone mr-1"></i>@(string.IsNullOrWhiteSpace(clinic.Phone) ? "Đang cập nhật" : clinic.Phone)
                            </p>
                            <div class="mt-auto">
                                <a href="@Url.Action("Details", "Vet", new { id = clinic.Id })" class="btn btn-primary btn-block">
                                    <i class="fa fa-eye mr-1"></i> Xem chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-4">
            <i class="fa fa-info-circle mr-1"></i> Chưa có dữ liệu top phòng khám.
        </div>
    }
</section>

<style>
    .top-vet-hero {
        background: linear-gradient(135deg, #1f6feb 0%, #0f4c75 100%);
        color: #fff;
        padding: 46px 0;
        margin-bottom: 8px;
    }

    .top-vet-hero h1 {
        font-size: 2rem;
        font-weight: 700;
        margin: 10px 0 10px;
    }

    .top-vet-hero p {
        margin-bottom: 0;
        opacity: 0.95;
    }

    .hero-badge {
        background: rgba(255, 255, 255, 0.18);
        border: 1px solid rgba(255, 255, 255, 0.35);
        border-radius: 999px;
        padding: 6px 12px;
        font-size: 0.85rem;
    }

    .top-vet-card {
        position: relative;
        border: 0;
        border-radius: 14px;
        box-shadow: 0 10px 24px rgba(16, 24, 40, 0.1);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        overflow: hidden;
    }

    .top-vet-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 16px 30px rgba(16, 24, 40, 0.15);
    }

    .rank-badge {
        position: absolute;
        top: 10px;
        right: 10px;
        background: #111827;
        color: #fff;
        font-weight: 700;
        border-radius: 999px;
        padding: 4px 10px;
        font-size: 0.8rem;
    }

    .clinic-link {
        color: #1f2937;
        text-decoration: none;
        font-weight: 700;
    }

    .clinic-link:hover {
        color: #0d6efd;
    }
</style>

