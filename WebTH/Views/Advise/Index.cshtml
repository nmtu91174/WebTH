@model PagedList.PagedList<WebTH.Models.EF.News>
@using PagedList
@using PagedList.Mvc
@{
    ViewBag.Title = "Tư vấn";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<section class="bg-title-page flex-c-m p-t-160 p-b-80 p-l-15 p-r-15"
         style="background-image: url(/Content/assets/images/bg-title-page-3.jpg)">
    <h2 class="tit6 t-center" style="color:white;">Bài tư vấn</h2>
</section>

<section>
    <div class="bread-crumb bo5-b p-t-17 p-b-17">
        <div class="container">
            <a href="/" class="txt27"> Trang chủ </a>
            <span class="txt29 m-l-10 m-r-10">/</span>
            <span class="txt29"> Bài viết </span>
        </div>
    </div>
    <div class="container">
        <div class="row">
            <div class="col-md-8 col-lg-9">
                <div class="p-t-80 p-b-124 bo5-r h-full p-r-50 p-r-0-md bo-none-md">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <div class="blo4 p-b-63">
                                <div class="pic-blo4 hov-img-zoom bo-rad-10 pos-relative">
                                    <a href="/@item.Alias-n@(item.Id)">
                                        <img src="@item.Image" alt="@item.Title" />
                                    </a>
                                    <div class="date-blo4 flex-col-c-m">
                                        <span class="txt30 m-b-4"> @item.CreatedDate.ToString("dd") </span>
                                        <span class="txt31"> @item.CreatedDate.ToString("MMM"), @item.CreatedDate.ToString("yyyy") </span>
                                    </div>
                                </div>
                                <div class="text-blo4 p-t-33">
                                    <h4 class="p-b-16">
                                        <a href="/@item.Alias-n@(item.Id)" class="tit9">@item.Title </a>
                                    </h4>
                                    <div class="txt32 flex-w p-b-24">
                                        <span>
                                            by Admin
                                            <span class="m-r-6 m-l-4">|</span>
                                        </span>
                                        <span>
                                            @item.CreatedDate
                                            <span class="m-r-6 m-l-4">|</span>
                                        </span>
                                        <span>
                                            @item.Alias
                                            <span class="m-r-6 m-l-4">|</span>
                                        </span>
                                        <span> Comments </span>
                                    </div>
                                    <p>
                                        @item.Description
                                    </p>
                                    <a href="/@item.Alias-n@(item.Id)" class="dis-block txt4 m-t-30">
                                        Tiếp tục đọc
                                        <i class="fa fa-long-arrow-right m-l-10" aria-hidden="true"></i>
                                    </a>
                                </div>
                            </div>
                        }
                        <div class="row">
                            <div class="col-6"></div>
                            <div class="col-6" style="text-align: right">
                                @Html.PagedListPager(Model, page => Url.Action("Index", new { page }))
                            </div>
                        </div>
                    }
                </div>
            </div>
            <div class="col-md-4 col-lg-3">
                <div class="sidebar2 p-t-80 p-b-80 p-l-20 p-l-0-md p-t-0-md">
                    <div class="search-sidebar2 size12 bo2 pos-relative">
                        <input class="input-search-sidebar2 txt10 p-l-20 p-r-55" type="text" name="search"
                               placeholder="Search" />
                        <button class="btn-search-sidebar2 flex-c-m fa fa-search trans-0-4"></button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
