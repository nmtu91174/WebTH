
@{
    ViewBag.Title = "Đặt hàng thành công";
}

<style>
    /* Success Page Styles */
    .success-container {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 40px 20px;
    }

    .success-card {
        background: white;
        border-radius: 16px;
        padding: 60px 40px;
        max-width: 600px;
        width: 100%;
        text-align: center;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
        animation: slideUp 0.5s ease-out;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .success-icon {
        width: 100px;
        height: 100px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 30px;
        animation: bounce 0.6s ease-out;
    }

    @@keyframes bounce {
        0% {
            transform: scale(0);
        }
        50% {
            transform: scale(1.1);
        }
        100% {
            transform: scale(1);
        }
    }

    .success-icon i {
        font-size: 50px;
        color: white;
    }

    .success-title {
        font-size: 32px;
        font-weight: 700;
        color: #222;
        margin-bottom: 15px;
        margin-top: 0;
    }

    .success-subtitle {
        font-size: 16px;
        color: #666;
        margin-bottom: 40px;
        line-height: 1.6;
    }

    .order-details {
        background: #f9f9f9;
        border-radius: 12px;
        padding: 30px;
        margin-bottom: 40px;
        text-align: left;
    }

    .order-details p {
        display: flex;
        justify-content: space-between;
        margin: 12px 0;
        font-size: 14px;
        color: #555;
    }

    .order-details strong {
        color: #222;
    }

    .order-number {
        font-size: 16px;
        font-weight: 600;
        color: #667eea;
        word-break: break-all;
    }

    .success-actions {
        display: flex;
        gap: 15px;
        justify-content: center;
    }

    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 12px 35px;
        border: none;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        font-size: 14px;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(102, 126, 234, 0.3);
    }

    .btn-secondary {
        background: white;
        color: #667eea;
        padding: 12px 35px;
        border: 2px solid #667eea;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        font-size: 14px;
    }

    .btn-secondary:hover {
        background: #f9f9f9;
    }

    .success-message {
        font-size: 14px;
        color: #27ae60;
        background: #d4edda;
        padding: 15px;
        border-radius: 6px;
        border-left: 4px solid #27ae60;
        margin-bottom: 30px;
    }

    @@media (max-width: 768px) {
        .success-card {
            padding: 40px 20px;
        }

        .success-title {
            font-size: 24px;
        }

        .success-actions {
            flex-direction: column;
        }

        .btn-primary,
        .btn-secondary {
            width: 100%;
        }
    }
</style>

<section class="success-container">
    <div class="success-card">
        <div class="success-icon">
            <i class="fa fa-check"></i>
        </div>

        <h1 class="success-title">Đặt hàng thành công!</h1>

        <div class="success-message">
            <i class="fa fa-info-circle"></i> Cảm ơn bạn đã mua hàng. Đơn hàng của bạn đã được xác nhận.
        </div>

        <p class="success-subtitle">
            Chúng tôi rất vui được phục vụ bạn. Đơn hàng của bạn sẽ sớm được xử lý và giao đến địa chỉ của bạn trong thời gian sớm nhất.
        </p>

        <div class="order-details">
            <p>
                <strong>Mã đơn hàng:</strong>
                <span class="order-number">ORD-@DateTime.Now.ToString("yyyyMMddHHmmss")</span>
            </p>
            <p>
                <strong>Ngày đặt hàng:</strong>
                <span>@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</span>
            </p>
            <p>
                <strong>Trạng thái:</strong>
                <span style="color: #27ae60; font-weight: 600;">Đã xác nhận</span>
            </p>
        </div>

        <div class="success-actions">
            <a href="/" class="btn-primary">Tiếp tục mua sắm</a>
            <a href="/Account/Profile" class="btn-secondary">Xem đơn hàng</a>
        </div>
    </div>
</section>

